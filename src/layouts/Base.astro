---
import '../styles/global.css';
import LangToggle from '../components/LangToggle.astro';
import IdeaBubbles from '../components/IdeaBubbles.astro';
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  pathFor: Record<Lang, string>;   // FR/EN equivalents of the current page
}
const { lang, title, description = '', pathFor } = Astro.props;
const here = Astro.url.pathname;
const blogHref = `/${lang}/blog`;
const homeHref = `/${lang}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Newsreader:ital,opsz@0,6..72;1,6..72&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <IdeaBubbles side="left" />
    <IdeaBubbles side="right" />
    <div class="wrap">
      <header class="bar">
        <a class="brand" href={homeHref}>{t(lang, 'site.name')}</a>
        <nav>
          <a href={homeHref} aria-current={here === homeHref ? 'page' : undefined}>{t(lang, 'nav.home')}</a>
          <a href={blogHref} aria-current={here.startsWith(blogHref) ? 'page' : undefined}>{t(lang, 'nav.blog')}</a>
          <LangToggle current={lang} pathFor={pathFor} />
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>© {new Date().getFullYear()} {t(lang, 'site.name')}</footer>
    </div>
  </body>
</html>
